# RStudio and IDE files
^.*\.Rproj$
^\.Rproj\.user$
^\.claude$
^CLAUDE\.md$
^\.gemini$
^GEMINI\.md$
^\.positai$

# Project Metadata and CRAN Documentation
^README\.Rmd$
^LICENSE\.md$
^cran-comments\.md$
^CRAN_READINESS_REVIEW\.md$
^issue-list$

# Development and CI Configuration
^\.github$
^_pkgdown\.yml$
^docs$
^pkgdown$
^\.covrignore$
^codecov\.yml$
^\.lintr$
^\.pre-commit-config\.yaml$

# Source Code Archives and Examples
^archive$
^examples$
^tests/test_queries\.R$

# Temporary and Generated Files
^vignettes/.*\.html$
^.*\.Rcheck$
